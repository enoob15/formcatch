# Core app configuration
FORMCATCH_SECRET=replace-with-a-32-byte-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=replace-with-your-smtp-password
SMTP_FROM=noreply@example.com
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe hosted checkout configuration
# No publishable key is required because checkout uses a server-created redirect session.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Prefer explicit Stripe price IDs for production.
STRIPE_PRO_PRICE_ID=price_replace_me_for_5_dollars
STRIPE_TEAM_PRICE_ID=price_replace_me_for_15_dollars

# Optional: use a local Stripe-compatible endpoint during integration tests.
# STRIPE_API_BASE=http://127.0.0.1:12111/v1
